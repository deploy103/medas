[Unit]
Description=Personal Vault API
After=network.target

[Service]
User=personal-vault
Group=personal-vault
WorkingDirectory=/opt/personal-vault/backend
EnvironmentFile=/etc/personal-vault.env
ExecStart=/opt/personal-vault/.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
