# 이 파일은 예시입니다. 앱은 자동으로 .env를 읽지 않으므로 필요하면 shell에서 export 하세요.
VAULT_SECRET_KEY=replace-with-long-random-secret
VAULT_PUBLIC_BASE_URL=http://localhost:8000
VAULT_CORS_ORIGIN=http://localhost:5173
VAULT_STORAGE_QUOTA_BYTES=10737418240
VAULT_MAX_UPLOAD_BYTES=536870912
# VAULT_STORAGE_DIR=/absolute/path/to/storage
# VAULT_DATABASE_URL=sqlite:////absolute/path/to/vault.db
